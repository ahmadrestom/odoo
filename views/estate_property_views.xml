<?xml version="1.0"?>
<odoo>
    <record id="estate_property_list" model="ir.ui.view">
        <field name="name">estate.property.list</field>
        <field name="model">estate.property</field>
        <field name="type">list</field>
        <field name="arch" type="xml">
            <list string="Properties">
                <field name="name" string="Title" />
                <field name="postcode" string="Postcode" />
                <field name="bedrooms" string="Bedrooms" />
                <field name="living_area" string="Living Area (sqm)" />
                <field name="expected_price" string="Expected Price" />
                <field name="selling_price" string="Selling Price" />
                <field name="date_availability" string="Available From" />
                <field name="property_type_id" />
            </list>
        </field>
    </record>

    <record id="estate_property_form" model="ir.ui.view">
        <field name="name">estate.property.form</field>
        <field name="model">estate.property</field>
        <field name="type">form</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <h1>
                        <field name="name" />
                    </h1>
                    <group>
                        <group>
                            <field name="postcode" />
                            <field name="expected_price" />
                            <field name="best_price" string="Best Offer" />
                        </group>
                        <group>
                            <field name="date_availability" />
                            <field name="selling_price" />
                        </group>
                    </group>
                    <label for="description" string="Description" />
                    <field name="description"
                        placeholder="When duplicated, status and date are not copied" />
                    <field name="tag_ids" position="after">
                        <field name="tag_ids" widget="many2many_tags" />
                    </field>
                    <field name="property_type_id" position="after">
                        <field name="property_type_id" />
                    </field>
                    <group>
                        <field name="bedrooms" />
                        <field name="living_area" string="Living Area (sqm)" />
                        <field name="facades" />
                        <field name="garage" />
                        <field name="garden" />
                        <field name="garden_area" string="Garden Area (sqm)" />
                        <field name="garden_orientation" />
                        <field name="total_area" string="Total Area (sqm)" />

                    </group>
                    <group>
                        <group>
                            <field name="salesperson_id" string="Salesman" />
                        </group>
                        <group>
                            <field name="buyer_id" string="Buyer" />
                        </group>
                    </group>
                    <!-- <notebook>
                        <page string="Offers">
                            <field name="offer_ids">
                                <tree>
                                    <field name="price" />
                                    <field name="partner_id" />
                                    <field name="status" />
                                </tree>
                            </field>
                        </page>
                    </notebook> -->
                </sheet>
            </form>
        </field>
    </record>

    <record id="estate_property_search" model="ir.ui.view">
        <field name="name">estate.property.search</field>
        <field name="model">estate.property</field>
        <field name="type">search</field>
        <field name="arch" type="xml">
            <search>

                <field name="name" string="Title" />
                <field name="postcode" string="Postcode" />
                <field name="expected_price" string="Expected Price" />
                <field name="bedrooms" string="Bedrooms" />
                <field name="living_area" string="Living Area (sqm)" />
                <field name="facades" string="Facades" />
                <field name="facades" position="after">
                    <field name="property_type_id" />
                </field>


                <filter string="Available" name="available" domain="[('state','=','available')]" />


                <group expand="0" string="Group By">
                    <filter string="Postcode" name="group_by_postcode"
                        context="{'group_by':'postcode'}" />
                    <filter string="Selling Price" name="group_by_price"
                        context="{'group_by':'selling_price'}" />
                    <filter string="Available From" name="group_by_date"
                        context="{'group_by':'date_availability'}" />
                </group>
            </search>
        </field>
    </record>

    <record id="estate_property_action" model="ir.actions.act_window">
        <field name="name">Properties</field>
        <field name="res_model">estate.property</field>
        <field name="view_mode">tree,form</field>
        <field name="view_ids" eval="[
            (0, 0, {'view_mode': 'tree', 'view_id': ref('estate_property_tree')}),
            (0, 0, {'view_mode': 'form', 'view_id': ref('estate_property_form')})
        ]"/>
    </record>
</odoo>